#!/usr/bin/env bash
set -e

# Parse arguments for verbosity
VERBOSE=0
for arg in "$@"; do
  if [ "$arg" = "-v" ] || [ "$arg" = "--verbose" ]; then
    VERBOSE=1
  fi
done

# Scan skills
skills=()
descriptions=()
paths=()
enabled=()

for dir in skills/*/; do
  if [ -f "${dir}SKILL.md" ]; then
    # Extract name from frontmatter
    name=$(grep -m1 '^name:' "${dir}SKILL.md" | sed 's/name://' | tr -d '"'\'' ')
    [ -z "$name" ] && name=$(basename "$dir")

    # Extract description from frontmatter
    desc=$(grep -m1 '^description:' "${dir}SKILL.md" | sed 's/description://' | sed 's/^[[:space:]]*//' | tr -d '"'\''')

    skills+=("$name")
    descriptions+=("$desc")
    paths+=("$(cd "$dir" && pwd)")
    enabled+=(1) # Enabled by default
  fi
done

if [ ${#skills[@]} -eq 0 ]; then
  echo "No skills found in skills/ directory."
  exit 0
fi

# 1. Interactive Menu to Toggle Skills
while true; do
  clear 2>/dev/null || true
  echo -e "\033[1;36m✨ Antigravity Skill Installer ✨\033[0m"
  echo "---------------------------------"
  echo "Toggle skills to enable:"
  echo

  for i in "${!skills[@]}"; do
    status="[ ]"
    if [ "${enabled[$i]}" -eq 1 ]; then
      status="[\033[1;32m✓\033[0m]"
    fi
    echo -e " $status  $((i+1)). \033[1m${skills[$i]}\033[0m"
    if [ -n "${descriptions[$i]}" ]; then
      echo -e "        \033[3m${descriptions[$i]}\033[0m"
    fi
    echo
  done

  echo "Commands:"
  echo "  • [Number] to toggle selection"
  echo "  • 'a' to select all | 'n' to select none"
  echo "  • 'Enter' (or 'y') to confirm"
  echo "  • 'q' to quit"
  echo

  read -p "Action [number/a/n/y/q]: " action
  action=$(echo "$action" | tr -d '[:space:]')

  if [ "$action" = "q" ]; then
    echo "Exiting without making changes."
    exit 0
  fi
  if [ "$action" = "y" ] || [ -z "$action" ]; then
    break
  fi
  if [ "$action" = "a" ]; then
    for i in "${!skills[@]}"; do enabled[$i]=1; done
    continue
  fi
  if [ "$action" = "n" ]; then
    for i in "${!skills[@]}"; do enabled[$i]=0; done
    continue
  fi

  if [[ "$action" =~ ^[0-9]+$ ]] && [ "$action" -ge 1 ] && [ "$action" -le ${#skills[@]} ]; then
    idx=$((action - 1))
    if [ "${enabled[$idx]}" -eq 1 ]; then
      enabled[$idx]=0
    else
      enabled[$idx]=1
    fi
  else
    read -p "Invalid option. Press Enter to try again."
  fi
done

# 2. Automatic CLI & Target Folder Detection (No Prompts)
if [ "$VERBOSE" -eq 1 ]; then
  echo -e "\n🔍 Detecting installed CLI tools..."
fi

detected_clis=()
if command -v agy >/dev/null 2>&1; then
  detected_clis+=("agy")
fi
if command -v antigravity >/dev/null 2>&1; then
  detected_clis+=("antigravity")
fi

if [ ${#detected_clis[@]} -gt 0 ] && [ "$VERBOSE" -eq 1 ]; then
  echo "✓ Detected CLI tools: ${detected_clis[*]}"
fi

# Define target paths automatically
targets=()
targets+=("$HOME/.agents")
if [ -d "$HOME/.gemini/config" ]; then
  targets+=("$HOME/.gemini/config")
fi
if [ -d "$HOME/.copilot" ]; then
  targets+=("$HOME/.copilot")
fi
if [ -d "$HOME/.claude" ]; then
  targets+=("$HOME/.claude")
fi

# 3. Softlink Enabled Skills (No Prompts)
repo_dir=$(pwd)
for target in "${targets[@]}"; do
  if [ "$VERBOSE" -eq 1 ]; then
    echo -e "\nDeploying to $target..."
  fi
  mkdir -p "$target/skills"
  
  # Clean up old metadata files in destination
  rm -f "$target/skills.json"
  rm -rf "$target/enabled-skills"

  linked_count=0
  for i in "${!skills[@]}"; do
    dest_path="$target/skills/${skills[$i]}"
    
    # Remove existing folder or symlink
    if [ -e "$dest_path" ] || [ -L "$dest_path" ]; then
      rm -rf "$dest_path"
    fi

    if [ "${enabled[$i]}" -eq 1 ]; then
      ln -s "${paths[$i]}" "$dest_path"
      linked_count=$((linked_count + 1))
      if [ "$VERBOSE" -eq 1 ]; then
        echo "  ✓ Linked skill: ${skills[$i]}"
      fi
    fi
  done

  # Link AGENTS.md rules
  if [ -f "$repo_dir/AGENTS.md" ]; then
    dest_agents="$target/AGENTS.md"
    if [ -e "$dest_agents" ] || [ -L "$dest_agents" ]; then
      rm -f "$dest_agents"
    fi
    ln -sf "$repo_dir/AGENTS.md" "$dest_agents"
    if [ "$VERBOSE" -eq 1 ]; then
      echo "  ✓ Linked AGENTS.md"
    fi
  fi

  if [ "$VERBOSE" -eq 0 ]; then
    echo "✓ Linked $linked_count skills and AGENTS.md rules to $target"
  fi
done

echo -e "\n\033[1;32m✨ Automatic symlink deployment complete!\033[0m"
