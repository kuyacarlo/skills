#!/usr/bin/env bash
set -e

# Scan skills
skills=()
descriptions=()
paths=()
enabled=()

for dir in skills/*/; do
  if [ -f "${dir}SKILL.md" ]; then
    # Extract name from frontmatter
    name=$(grep -m1 '^name:' "${dir}SKILL.md" | sed 's/name://' | tr -d '"'\'' ')
    [ -z "$name" ] && name=$(basename "$dir")
    
    # Extract description from frontmatter
    desc=$(grep -m1 '^description:' "${dir}SKILL.md" | sed 's/description://' | sed 's/^[[:space:]]*//' | tr -d '"'\''')
    
    skills+=("$name")
    descriptions+=("$desc")
    paths+=("$(cd "$dir" && pwd)")
    enabled+=(1) # Enabled by default
  fi
done

if [ ${#skills[@]} -eq 0 ]; then
  echo "No skills found in skills/ directory."
  exit 0
fi

while true; do
  clear 2>/dev/null || true
  echo -e "\033[1;36m✨ Antigravity Skill Installer ✨\033[0m"
  echo "---------------------------------"
  echo "Toggle skills to enable:"
  echo

  for i in "${!skills[@]}"; do
    status="[ ]"
    if [ "${enabled[$i]}" -eq 1 ]; then
      status="[\033[1;32m✓\033[0m]"
    fi
    echo -e " $status  $((i+1)). \033[1m${skills[$i]}\033[0m"
    if [ -n "${descriptions[$i]}" ]; then
      echo -e "        \033[3m${descriptions[$i]}\033[0m"
    fi
    echo
  done

  echo "Commands:"
  echo "  • [Number] to toggle selection"
  echo "  • 'a' to select all | 'n' to select none"
  echo "  • 'Enter' (or 'y') to confirm"
  echo "  • 'q' to quit"
  echo
  
  read -p "Action [number/a/n/y/q]: " action
  action=$(echo "$action" | tr -d '[:space:]')
  
  if [ "$action" = "q" ]; then
    echo "Exiting without making changes."
    exit 0
  fi
  if [ "$action" = "y" ] || [ -z "$action" ]; then
    break
  fi
  if [ "$action" = "a" ]; then
    for i in "${!skills[@]}"; do enabled[$i]=1; done
    continue
  fi
  if [ "$action" = "n" ]; then
    for i in "${!skills[@]}"; do enabled[$i]=0; done
    continue
  fi
  
  if [[ "$action" =~ ^[0-9]+$ ]] && [ "$action" -ge 1 ] && [ "$action" -le ${#skills[@]} ]; then
    idx=$((action - 1))
    if [ "${enabled[$idx]}" -eq 1 ]; then
      enabled[$idx]=0
    else
      enabled[$idx]=1
    fi
  else
    read -p "Invalid option. Press Enter to try again."
  fi
done

# Install files locally
TARGET_DIR="$HOME/.agents"
mkdir -p "$TARGET_DIR"

# Clean up any old external path registrations and enabled-skills directories
rm -f "$TARGET_DIR/skills.json"
rm -rf "$TARGET_DIR/enabled-skills"

# Create skills directory if it doesn't exist
mkdir -p "$TARGET_DIR/skills"

for i in "${!skills[@]}"; do
  if [ "${enabled[$i]}" -eq 1 ]; then
    dest_path="$TARGET_DIR/skills/${skills[$i]}"
    if [ -d "$dest_path" ]; then
      # Check if files in destination match the source exactly
      if diff -r "${paths[$i]}" "$dest_path" >/dev/null 2>&1; then
        echo "✓ Skill '${skills[$i]}' is already up to date."
      else
        echo -e "\033[1;33m⚠️ Skill '${skills[$i]}' already exists in destination and has differences.\033[0m"
        read -p "Overwrite target? [y/N]: " overwrite
        if [[ "$overwrite" =~ ^[yY]$ ]]; then
          rm -rf "$dest_path"
          cp -r "${paths[$i]}" "$dest_path"
          echo "✓ Overwrote and updated skill: ${skills[$i]}"
        else
          echo "Skipping update of skill: ${skills[$i]}"
        fi
      fi
    else
      cp -r "${paths[$i]}" "$dest_path"
      echo "✓ Installed skill: ${skills[$i]}"
    fi
  fi
done

# Copy AGENTS.md rules locally with differences check
repo_dir=$(pwd)
if [ -f "$repo_dir/AGENTS.md" ]; then
  dest_agents="$TARGET_DIR/AGENTS.md"
  if [ -f "$dest_agents" ]; then
    if cmp -s "$repo_dir/AGENTS.md" "$dest_agents"; then
      echo "✓ AGENTS.md rules are already up to date."
    else
      echo -e "\033[1;33m⚠️ AGENTS.md rules already exist in destination and have differences.\033[0m"
      read -p "Overwrite target? [y/N]: " overwrite
      if [[ "$overwrite" =~ ^[yY]$ ]]; then
        cp "$repo_dir/AGENTS.md" "$dest_agents"
        echo "✓ Overwrote and updated AGENTS.md rules"
      else
        echo "Skipping update of AGENTS.md rules"
      fi
    fi
  else
    cp "$repo_dir/AGENTS.md" "$dest_agents"
    echo "✓ Copied AGENTS.md rules"
  fi
fi

echo -e "\n\033[1;32m✓ Customizations successfully processed!\033[0m"
echo "You can now safely delete this installer/repository folder if desired."
